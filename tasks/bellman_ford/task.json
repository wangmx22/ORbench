{
  "task_id": "bellman_ford",
  "name": "Bellman-Ford Single Source Shortest Path",
  "category": "graph_traversal",
  "difficulty": 3,
  "tags": ["iterative", "atomic", "convergence_detection", "CSR_graph"],

  "input_sizes": {
    "large":  {"V": 500000, "E": 2500000, "seed": 42}
  },

  "correctness": {
    "mode": "numerical",
    "atol": 0.01,
    "rtol": 0.01,
    "allow_different_iterations": true
  },

  "timing": {
    "warmup": 3,
    "trials": 10,
    "timeout": 180
  },

  "build_command": "nvcc -O2 -arch=sm_89 -o solution solution.cu",
  "extra_build_flags": "",

  "gpu_optimization_points": [
    "atomicMin_float",
    "early_termination",
    "persistent_kernel",
    "shared_memory_reduction",
    "edge_vs_node_parallel"
  ]
}
